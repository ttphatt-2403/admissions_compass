rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Messages collection rules
    match /messages/{messageId} {
      // Anyone can read messages (even without login)
      allow read: if true;
      
      // Only authenticated users can create messages
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasAll(['author', 'content', 'timestamp', 'likes'])
                    && request.resource.data.likes == 0
                    && request.resource.data.content is string
                    && request.resource.data.author is string;
      
      // Only authenticated users can update (for likes)
      // Can only update the 'likes' field
      allow update: if request.auth != null 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                    && request.resource.data.likes > resource.data.likes;
      
      // Only allow deletion by authenticated users (optional, can be removed)
      allow delete: if request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'admin@dashboard.com',
        'adminlabantuyensinh12345@gmail.com'
      ];
    }

    match /payment_orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read: if (request.auth != null && resource.data.uid == request.auth.uid) || isAdmin();
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'paidAt', 'payosRef', 'credited']);
    }

    match /siteStats/{doc} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
    }

    match /siteStatsDays/{doc} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
    }

    match /siteStatsPages/{doc} {
      allow read: if isAdmin();
      allow write: if request.auth != null;
    }

    match /users/{uid} {
      allow read: if (request.auth != null && request.auth.uid == uid) || isAdmin();
      allow write: if true; // webhook cần ghi không có auth
      match /transactions/{txId} {
        allow read: if (request.auth != null && request.auth.uid == uid) || isAdmin();
        allow write: if true;
      }
    }
  }
}
