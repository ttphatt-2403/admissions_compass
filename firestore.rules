rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Messages collection rules
    match /messages/{messageId} {
      // Anyone can read messages (even without login)
      allow read: if true;
      
      // Only authenticated users can create messages
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasAll(['author', 'content', 'timestamp', 'likes'])
                    && request.resource.data.likes == 0
                    && request.resource.data.content is string
                    && request.resource.data.author is string;
      
      // Only authenticated users can update (for likes)
      // Can only update the 'likes' field
      allow update: if request.auth != null 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                    && request.resource.data.likes > resource.data.likes;
      
      // Only allow deletion by authenticated users (optional, can be removed)
      allow delete: if request.auth != null;
    }
  }
}
