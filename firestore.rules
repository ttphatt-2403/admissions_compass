rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Messages collection rules
    match /messages/{messageId} {
      // Anyone can read messages (even without login)
      allow read: if true;
      
      // Only authenticated users can create messages
      allow create: if request.auth != null 
                    && request.resource.data.keys().hasAll(['author', 'content', 'timestamp', 'likes'])
                    && request.resource.data.likes == 0
                    && request.resource.data.content is string
                    && request.resource.data.author is string;
      
      // Only authenticated users can update (for likes)
      // Can only update the 'likes' field
      allow update: if request.auth != null 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                    && request.resource.data.likes > resource.data.likes;
      
      // Only allow deletion by authenticated users (optional, can be removed)
      allow delete: if request.auth != null;
    }

    match /payment_orders/{orderId} {
      // Authenticated user creates their own order
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      // Authenticated user reads their own order (needed for onSnapshot)
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      // Webhook (no auth) updates status/paidAt/payosRef; client updates credited flag
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'paidAt', 'payosRef', 'credited']);
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /transactions/{txId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
